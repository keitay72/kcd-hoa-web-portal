# Global
APP_ENV=dev

# Mobile App
MOBILE_SUPABASE_URL=
MOBILE_SUPABASE_ANON_KEY=

# Admin Web App
ADMIN_SUPABASE_URL=
ADMIN_SUPABASE_ANON_KEY=

# Backend / Edge Functions (never expose service role key to clients)
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_INVITE_REDIRECT_URL=

# Realtime channels prefix
REALTIME_CHANNEL_PREFIX=kcd

# Stripe SaaS Billing (Edge Functions only; never expose secret keys to Flutter)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:8080/admin/tenants
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:8080/admin/tenants
